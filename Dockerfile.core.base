# Dockerfile.core.base
FROM python:3.10-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    curl \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir \
    flask \
    requests \
    scikit-learn \
    numpy \
    pandas \
    pyyaml \
    rich \
    scipy \
    joblib